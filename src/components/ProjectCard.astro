---
const { title, description, image, github, design } = Astro.props;

const hasGithub = typeof github === "string" && github.trim().length > 0;
const hasDesign = typeof design === "string" && design.trim().length > 0;
---

<article class="project-card">
  {image ? (
    <img src={image} alt={title} loading="lazy" class="card-img" />
  ) : (
    <div class="image-placeholder">🚧 System Design Only</div>
  )}

  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>

    <div class="links">
      {hasGithub && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="github-link"
        >
          View on GitHub →
        </a>
      )}

      {hasDesign && (
        <a
          href={design}
          target="_blank"
          rel="noopener noreferrer"
          class="design-link"
        >
          View System Design →
        </a>
      )}
    </div>
  </div>
</article>

<style>
.project-card {
  background: var(--bg2);
  color: var(--text);
  border-radius: 1rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(56, 189, 248, 0.18);
}

/* ❌ NO TRANSFORMS — EVER */

.card-img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  border-bottom: 1px solid rgba(56, 189, 248, 0.25);
  display: block;
}

.image-placeholder {
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  color: #fbbf24;
  background: var(--bg1);
  border-bottom: 1px solid rgba(56, 189, 248, 0.25);
}

.card-content {
  padding: 1.2rem 1.5rem;
}

.card-content h3 {
  color: #93c5fd;
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.card-content p {
  color: var(--text);
  font-size: 0.95rem;
  margin-bottom: 1rem;
  line-height: 1.5;
}

.links {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.github-link,
.design-link {
  color: #38bdf8;
  font-weight: 700;
  text-decoration: underline;
}

/* ✅ Print-safe: nothing special needed anymore */
</style>
