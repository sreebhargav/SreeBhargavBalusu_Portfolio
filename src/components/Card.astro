---
const {
  name,
  position,
  aboutMe,
  linkedin,
  github,
  cvLink,
  profileImage,
  contactEmail,
} = Astro.props;
---

<section class="intro-card">
  <div class="card-wrapper">
    <img src={profileImage} alt={name} class="profile" />

    <div class="info">
      <h1>{name}</h1>
      <h3>{position}</h3>

      <p class="tagline">
        Backend & AI Systems Engineer | Building Scalable Platforms & Multi-Agent DevTools
      </p>

      <p class="about">{aboutMe}</p>

      <!-- BUTTON LINKS -->
      <div class="links">
        <a href={linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={`mailto:${contactEmail}`} rel="noopener noreferrer">Email</a>
      </div>

      <a
        href={cvLink}
        target="_blank"
        rel="noopener noreferrer"
        class="resume-button"
      >
        📄 View Full Resume
      </a>
    </div>
  </div>
</section>

<style>
/* =========================
   LAYOUT
========================= */
.intro-card {
  background: transparent;
  color: var(--text);
  padding: 4rem 2rem;
  display: flex;
  justify-content: center;
}

.card-wrapper {
  display: flex;
  align-items: center;
  gap: 2rem;
  max-width: 1000px;
  flex-wrap: wrap;
}

.profile {
  width: 220px;
  height: 220px;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid #38bdf8;
  box-shadow: 0 0 25px rgba(56, 189, 248, 0.35);
}

.info {
  flex: 1;
  min-width: 300px;
}

/* =========================
   TEXT
========================= */
h1 {
  font-size: 2.2rem;
  color: #60a5fa;
  margin-bottom: 0.25rem;
}

h3 {
  color: #93c5fd;
  margin-bottom: 0.6rem;
  font-weight: 600;
}

.tagline {
  color: #94a3b8;
  font-size: 1rem;
  font-weight: 500;
  margin-bottom: 1rem;
}

.about {
  max-width: 620px;
  line-height: 1.6;
  margin-bottom: 1.5rem;
  color: var(--text);
}

/* =========================
   BUTTONS (PDF SAFE)
========================= */
.links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
}

.links a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.55rem 1.1rem;
  border-radius: 0.55rem;
  font-weight: 700;
  text-decoration: none;
  border: 1px solid rgba(56, 189, 248, 0.7);
  color: var(--text);
  background: transparent;
}

/* ✅ NO TRANSFORMS — SAFE FOR PDF */
.links a:hover {
  box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.35);
}

.resume-button {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 1.1rem;
  padding: 0.6rem 1.1rem;
  border-radius: 0.6rem;
  border: 1px solid rgba(56, 189, 248, 0.8);
  color: var(--text);
  font-weight: 800;
  text-decoration: none;
  background: transparent;
}

/* ✅ NO TRANSFORMS — SAFE FOR PDF */
.resume-button:hover {
  box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.45);
}

/* =========================
   PRINT / PDF (KEEP SAME LOOK)
========================= */
@media print {
  .intro-card {
    background: transparent !important;
    color: var(--text) !important;
  }

  /* Remove glow only */
  .profile {
    box-shadow: none !important;
  }

  /* Ensure hitboxes remain */
  a {
    box-shadow: none !important;
  }
}
</style>
