---
const navItems = [
  { name: "About", href: "#about" },
  { name: "Experience", href: "#experience" },
  { name: "Skills", href: "#skills" },
  { name: "Projects", href: "#projects" },
  { name: "System Design", href: "#system-designs" },
  { name: "Contact", href: "#contact" },
];
---

<nav class="navbar">
  <div class="nav-container">
    <a href="#about" class="logo">Sree&nbsp;Bhargav&nbsp;<span>Balusu</span></a>

    <!-- Hamburger button -->
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">☰</button>

    <!-- Navigation links -->
    <ul class="nav-links" id="nav-links">
      {navItems.map((item) => (
        <li><a href={item.href}>{item.name}</a></li>
      ))}
    </ul>
  </div>
</nav>

<!-- ✅ JS: Scroll highlight + mobile toggle -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll(".nav-links a");
    const menuToggle = document.getElementById("menu-toggle");
    const navMenu = document.getElementById("nav-links");

    // Scroll highlight
    function activateLink() {
      let current = "";
      sections.forEach((section) => {
        const sectionTop = section.offsetTop - 120;
        if (window.scrollY >= sectionTop) {
          current = section.getAttribute("id");
        }
      });

      navLinks.forEach((link) => {
        link.classList.remove("active");
        if (link.getAttribute("href") === `#${current}`) {
          link.classList.add("active");
        }
      });
    }

    window.addEventListener("scroll", activateLink);

    // Mobile toggle
    menuToggle.addEventListener("click", () => {
      navMenu.classList.toggle("show");
      menuToggle.textContent = navMenu.classList.contains("show") ? "✖" : "☰";
    });

    // Close menu when a link is clicked
    navLinks.forEach((link) => {
      link.addEventListener("click", () => navMenu.classList.remove("show"));
    });
  });
</script>

<style>
.navbar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(2, 6, 23, 0.9);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(56, 189, 248, 0.3);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
}

.nav-container {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 1.5rem;
}

.logo {
  font-size: 1.4rem;
  font-weight: 700;
  color: #38bdf8;
  text-decoration: none;
  letter-spacing: 0.5px;
}

.logo span {
  color: #0ea5e9;
}

/* Nav links */
.nav-links {
  display: flex;
  list-style: none;
  gap: 1.5rem;
}

.nav-links a {
  color: #e2e8f0;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.3s ease;
}

.nav-links a:hover {
  color: #38bdf8;
}

/* Active highlight */
.nav-links a.active {
  color: #38bdf8;
  border-bottom: 2px solid #38bdf8;
  padding-bottom: 2px;
}

/* Mobile Menu */
.menu-toggle {
  display: none;
  font-size: 1.8rem;          /* slightly larger for tap comfort */
  background: none;
  border: none;
  color: #38bdf8;
  cursor: pointer;
  z-index: 60;               /* keeps it above moon icon */
  position: relative;
  margin-right: 2.5rem;      /* pushes away from the moon icon */
  padding: 0.3rem 0.6rem;    /* improves tap area */
}


/* Responsive for mobile */
@media (max-width: 768px) {
  /* ensure moon and hamburger don't overlap */
  .theme-toggle {
    margin-right: 0.5rem;
  }
}

  .nav-links {
    display: none;
    position: absolute;
    top: 60px;
    right: 10px;
    flex-direction: column;
    background: rgba(2, 6, 23, 0.98);
    border: 1px solid rgba(56, 189, 248, 0.3);
    border-radius: 8px;
    padding: 1rem;
    width: 200px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.4);
    transform: translateY(-20px);
    opacity: 0;
    transition: all 0.25s ease;
  }

  .nav-links.show {
    display: flex;
    transform: translateY(0);
    opacity: 1;
  }

  .nav-links a {
    padding: 0.6rem 0;
  }
}
</style>
