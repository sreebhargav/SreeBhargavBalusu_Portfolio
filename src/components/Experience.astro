---
const experiences = [
  {
    company: "Vosyn Inc.",
    logo: "/images/Vosyn.png",
    role: "Software Engineer – Backend Developer (Aquarius)",
    period: "March 2025 – July 2025",
    description: [
      "Developed 15+ RESTful APIs using Java, Spring, and PostgreSQL microservices, improving response times by 40%.",
      "Optimized GCP Kubernetes stack for voice-processing services, achieving 99.98% uptime and cutting cloud costs by 20%.",
      "Built Node.js + PostgreSQL backend for Timesheets, reducing feature rollout time by 30% for 5,000+ entries monthly.",
    ],
  },
  {
    company: "University of Maryland, Baltimore County (UMBC)",
    logo: "/images/UMBC.png",
    role: "Graduate Assistant – Computer Architecture",
    period: "August 2024 – May 2025",
    description: [
      "Automated feedback distribution on AWS Lambda, reducing manual workload by 2 hours weekly.",
      "Enhanced Lab file system by 25% through I/O optimization and caching, cutting latency by 30%.",
      "Led adoption of CI/CD, Docker, and TDD among 5 TAs, reducing grading query time by 20%.",
    ],
  },
  {
    company: "University of Maryland, Baltimore County (UMBC)",
    logo: "/images/UMBC.png",
    role: "Research Assistant – Linear Quadratic State Estimation",
    period: "August 2023 – August 2024",
    description: [
      "Engineered Python robotic control models using Kalman filters, achieving 95% accuracy on noisy data.",
      "Reduced error rate by 15% via cross-validation and constrained least-squares optimization.",
      "Built scalable fault-tolerant estimation systems with MATLAB and NumPy for real-time robotics.",
    ],
  },
];
---

<section class="experience">
  <h2>Experience</h2>

  <div class="exp-grid">
    {experiences.map((exp) => (
      <div class="exp-card">
        <div class="exp-header">
          <img src={exp.logo} alt={exp.company} class="logo" />
          <div>
            <h3>{exp.role}</h3>
            <p class="company">{exp.company}</p>
            <p class="period">{exp.period}</p>
          </div>
        </div>

        <ul>
          {exp.description.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
.experience {
  padding: 4rem 2rem;
}

.experience h2 {
  text-align: center;
  color: #60a5fa;
  font-size: 2rem;
  margin-bottom: 2.5rem;
}

.exp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  max-width: 900px;
  margin: 0 auto;
}

.exp-card {
  background: var(--bg2);
  border: 1px solid rgba(56, 189, 248, 0.18);
  border-radius: 1rem;
  padding: 1.5rem 2rem;
}

.exp-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.logo {
  width: 50px;
  height: 50px;
  object-fit: contain;
  border-radius: 0.5rem;
}

.exp-card h3 {
  color: #93c5fd;
  margin: 0;
}

.company {
  color: #a5b4fc;
  font-weight: 500;
}

.period {
  color: #cbd5e1;
  font-size: 0.9rem;
}

ul {
  margin-top: 0.5rem;
  padding-left: 1.2rem;
}

li {
  margin-bottom: 0.6rem;
  color: var(--text);
  line-height: 1.6;
}

/* ✅ Print-safe */
@media print {
  .exp-card {
    border-color: #ccc;
  }
}
</style>
