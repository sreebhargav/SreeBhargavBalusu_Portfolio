---
const experiences = [
  {
  company: "DocuSign",
 logo: "/images/DocuSign-logo.webp",
  role: "Full Stack Developer",
  period: "Jan 2025 – Present",
  description: [
    "Built Java and Spring Boot microservices for document ingestion, validation, and metadata extraction, processing 150K+ documents annually across PostgreSQL, AWS S3, and Kafka pipelines.",
    "Developed secure REST APIs using Java, Spring Boot, OAuth2, RBAC, and PostgreSQL to manage document access, approval workflows, and audit trails, reducing unauthorized access issues by 35%.",
    "Built AI-powered document review services using Java, Spring Boot, OpenAI GPT-4o, LangChain, and RAG pipelines, reducing manual contract review effort by 40%.",
    "Improved document workflow dashboards using React.js, Next.js, TypeScript, and Tailwind CSS, simplifying approval tracking and reducing review turnaround time by 30%.",
    "Deployed AWS-based remediation services using Lambda, ECS, SQS, Docker, Kubernetes, Jenkins, and GitHub Actions, improving release reliability and maintaining 99.5% platform uptime.",
    "Implemented Prometheus, Grafana, structured audit logging, and HIPAA-aligned controls, reducing audit preparation effort by 25%."
  ],
},
  {
    company: "University of Maryland, Baltimore County (UMBC)",
    logo: "/images/UMBC.png",
    role: "Graduate Assistant – Computer Architecture",
    period: "August 2024 – May 2025",
    description: [
      "Automated feedback distribution on AWS Lambda, reducing manual workload by 2 hours weekly.",
      "Enhanced Lab file system by 25% through I/O optimization and caching, cutting latency by 30%.",
      "Led adoption of CI/CD, Docker, and TDD among 5 TAs, reducing grading query time by 20%.",
    ],
  },
{
  company: "Cigna",
  logo: "/images/Cigna.png",
  role: "Software Developer",
  period: "Jan 2022 – Jul 2023",
  description: [
    "Architected scalable microservices using Java, Spring Boot, REST APIs, and PostgreSQL to modernize fragmented EHR systems, centralizing patient records across 8+ hospitals.",
    "Engineered secure FHIR APIs, HL7 integrations, and payment services workflows with clinical teams, enabling real-time patient data exchange and reducing duplicate patient records by 25%.",
    "Designed high-throughput event-driven distributed systems using Apache Kafka, Redis, and asynchronous processing to support real-time healthcare workflows, reducing API latency by 20%.",
    "Modernized insurance claims infrastructure by collaborating with billing, fraud, product, and compliance teams to integrate eligibility verification APIs, reducing claims delays by 25%."
  ],
},
];
---

<section class="experience">
  <h2>Experience</h2>

  <div class="exp-grid">
    {experiences.map((exp) => (
      <div class="exp-card">
        <div class="exp-header">
          <img src={exp.logo} alt={exp.company} class="logo" />
          <div>
            <h3>{exp.role}</h3>
            <p class="company">{exp.company}</p>
            <p class="period">{exp.period}</p>
          </div>
        </div>

        <ul>
          {exp.description.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
.experience {
  padding: 4rem 2rem;
}

.experience h2 {
  text-align: center;
  color: #60a5fa;
  font-size: 2rem;
  margin-bottom: 2.5rem;
}

.exp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  max-width: 900px;
  margin: 0 auto;
}

.exp-card {
  background: var(--bg2);
  border: 1px solid rgba(56, 189, 248, 0.18);
  border-radius: 1rem;
  padding: 1.5rem 2rem;
}

.exp-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.logo {
  width: 50px;
  height: 50px;
  object-fit: contain;
  border-radius: 0.5rem;
}

.exp-card h3 {
  color: #93c5fd;
  margin: 0;
}

.company {
  color: #a5b4fc;
  font-weight: 500;
}

.period {
  color: #cbd5e1;
  font-size: 0.9rem;
}

ul {
  margin-top: 0.5rem;
  padding-left: 1.2rem;
}

li {
  margin-bottom: 0.6rem;
  color: var(--text);
  line-height: 1.6;
}

/* ✅ Print-safe */
@media print {
  .exp-card {
    border-color: #ccc;
  }
}
</style>