---
import ScrollReveal from "./ScrollReveal.jsx";

const systemDesigns = [
  {
    title: "AgentPR Workflow – AI-Powered PR Automation",
    image: "/images/AgentPRimage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_ai-opensource-developertools-activity-7333966925472976897-77sE",
  },
  {
    title: "Patient EMR Platform on AWS",
    image: "/images/PatientEMRImage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_systemdesign-aws-docker-activity-7350597366535593984-wV4x",
  },
  {
    title: "Social Media Platform with Real-Time & AWS EKS",
    image: "/images/SocialMediaImage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_workout-memes-devtips-activity-7353182863015432192-i-zz",
  },
  {
    title: "Real Estate Listing Platform on AWS",
    image: "/images/RealImage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_systemdesign-aws-s3-activity-7355657719288143872-xAnu",
  },
  {
    title: "AI Safety Middleware – Prompt Firewall",
    image: "/images/AIsafetyImage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_systemdesign-aisafety-securityengineering-activity-7382464101492613120-R7Qb",
  },
  {
    title: "Real-Time Drowsiness Detection & Alert System",
    image: "/images/DriverImage.png",
    link: "https://www.linkedin.com/posts/sreebhargavbalusu_systemdesign-ai-drowsinessdetection-activity-7358618739514171392-7l85",
  },
];
---

<section class="system-designs">
  <h2>System Design Highlights</h2>

  <ScrollReveal client:load delay={0.3}>
    <div class="design-grid">
      {systemDesigns.map((design) => (
        <a
          href={design.link}
          target="_blank"
          rel="noopener noreferrer"
          class="design-card"
        >
          <img src={design.image} alt={design.title} loading="lazy" />
          <div class="overlay">
            <h3>{design.title}</h3>
            <p>View Full Breakdown →</p>
          </div>
        </a>
      ))}
    </div>
  </ScrollReveal>
</section>

<style>
.system-designs {
  padding: 4rem 2rem;
}

.system-designs h2 {
  text-align: center;
  color: #60a5fa;
  font-size: 2.2rem;
  margin-bottom: 2.5rem;
}

.design-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.8rem;
  max-width: 1200px;
  margin: 0 auto;
}

.design-card {
  position: relative;
  overflow: hidden;
  border-radius: 1rem;
  text-decoration: none;
  display: block;
  border: 1px solid rgba(56, 189, 248, 0.2);
  background: var(--bg2);
}

/* ❌ NO TRANSFORMS — EVER */

.design-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
  filter: brightness(0.9);
}

.overlay {
  pointer-events: none;
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.75);
  color: #e2e8f0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.design-card:hover .overlay {
  opacity: 1;
}

.overlay h3 {
  color: #93c5fd;
  font-size: 1rem;
  margin-bottom: 0.4rem;
}

.overlay p {
  color: #38bdf8;
  font-weight: 700;
  font-size: 0.9rem;
}
</style>
