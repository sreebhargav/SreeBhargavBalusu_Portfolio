---
import ScrollReveal from "../components/ScrollReveal.jsx";

import Card from "../components/Card.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import SystemDesigns from "../components/SystemDesigns.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sree Bhargav Balusu | Portfolio"
  description="Software engineer specializing in AI, distributed systems, and full-stack development."
>

  <!-- ABOUT (Card is interactive → DO NOT wrap) -->
  <section id="about">
    <Card
      name="Sree Bhargav Balusu"
      position="Software Engineer"
      aboutMe={`Hey! I’m Sree — I graduated in May 2025 with a Master’s in Computer Science from UMBC. I worked as a Backend Developer at Vosyn Inc., building AI-driven systems for generative voice technology, and previously modeled autonomous and robotic behavior in dynamic environments. I’m passionate about creating reliable, intelligent backend systems.`}
      linkedin="https://www.linkedin.com/in/sreebhargavbalusu/"
      github="https://github.com/sreebhargav"
      cvLink="https://drive.google.com/file/d/1lVHGHA3utXWlgzMAFprUYRRRqDBCaX5e/view"
      profileImage="/images/pic1.jpg"
      contactEmail="sreebhargavbalusu@gmail.com"
    />
  </section>

  <!-- EXPERIENCE (safe to reveal content only) -->
  <section id="experience">
    <ScrollReveal client:load delay={0.2}>
      <Experience />
    </ScrollReveal>
  </section>

  <!-- SKILLS -->
  <section id="skills">
    <ScrollReveal client:load delay={0.2}>
      <Skills />
    </ScrollReveal>
  </section>

  <!-- PROJECTS -->
  <section id="projects">
    <ScrollReveal client:load delay={0.3}>
      <Projects />
    </ScrollReveal>
  </section>

  <!-- SYSTEM DESIGNS -->
  <section id="system-designs">
    <ScrollReveal client:load delay={0.3}>
      <SystemDesigns />
    </ScrollReveal>
  </section>

  <!-- CONTACT (INTERACTIVE → NEVER WRAP) -->
  <section id="contact">
    <div class="contact-container">
      <h2>📫 Get in Touch</h2>
      <p>
        I’m always open to discussing new roles, collaborations, or ideas in AI systems,
        backend engineering, and scalable architectures.
      </p>

      <div class="contact-links">
        <a
          href="https://mail.google.com/mail/?view=cm&fs=1&to=sreebhargavbalusu@gmail.com"
          target="_blank"
          rel="noopener noreferrer"
          class="email-btn"
        >
          ✉️ Email Me
        </a>

        <a
          href="https://www.linkedin.com/in/sreebhargavbalusu/"
          target="_blank"
          rel="noopener noreferrer"
          class="linkedin-btn"
        >
          🔗 Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
